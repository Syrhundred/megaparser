# NextAuth — required for session security
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-use-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# First admin user — used only by: npm run db:seed
ADMIN_EMAIL="madiev.inc@gmail.com"
ADMIN_PASSWORD="password"

# PostgreSQL connection string
# Local dev example: postgresql://postgres:password@localhost:5432/megaparser
DATABASE_URL="postgresql://postgres:password@localhost:5432/megaparser"

# Redis connection string (used by BullMQ)
# Local dev: redis://localhost:6379
REDIS_URL="redis://localhost:6379"

# Google Custom Search API — 100 free queries/day (web search)
# API Key: https://console.developers.google.com/ → enable "Custom Search API"
# CX (Search Engine ID): https://programmablesearchengine.google.com/
GOOGLE_API_KEY=""
GOOGLE_CX=""

# SerpAPI — 100 free queries/month (alternative web search)
# https://serpapi.com/
SERPAPI_KEY=""

# Yandex Maps Business Search — maps search for KZ/RU/CIS
# Free: 500 requests/day — https://developer.tech.yandex.ru/
YANDEX_MAPS_API_KEY=""

# SMTP settings for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
