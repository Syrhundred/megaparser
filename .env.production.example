# Copy to .env and fill in before running docker-compose up

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=https://your-domain.com

# First admin user (used only on first startup by the migrate service)
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=strong-password-here

# PostgreSQL password (used inside Docker network)
POSTGRES_PASSWORD=strong-db-password-here

# App port (default: 3000)
PORT=3000

# Optional: pre-configure SMTP (can also be set via Settings UI)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourname@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=Your Name <yourname@gmail.com>
